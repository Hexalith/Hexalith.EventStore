<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Testing utilities for the Hexalith event store — in-memory fakes, builders, and assertions for .NET event sourcing and CQRS test scenarios</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Hexalith.EventStore.Admin.Mcp.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Hexalith.EventStore.Client\Hexalith.EventStore.Client.csproj" />
    <ProjectReference Include="..\Hexalith.EventStore.Contracts\Hexalith.EventStore.Contracts.csproj" />
    <!-- Runtime-test utility dependency: aggregate actors, state stores, pub/sub helpers.
         Not required for the public projection adapter fake API (FakeProjectionActor uses Contracts only). -->
    <ProjectReference Include="..\Hexalith.EventStore.Server\Hexalith.EventStore.Server.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Shouldly" />
    <!-- NSubstitute is not used by this package's source and must not flow as a package dependency:
         it is pinned to a prerelease (6.0.0-rc.1) centrally, and a stable package may not carry a
         prerelease dependency (NU5104). PrivateAssets keeps it out of the published nuspec. -->
    <PackageReference Include="NSubstitute" PrivateAssets="all" />
    <PackageReference Include="xunit.v3.assert" />
  </ItemGroup>

</Project>
