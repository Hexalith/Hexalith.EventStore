{
  "realm": "hexalith",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "hexalith-eventstore",
      "name": "Hexalith EventStore",
      "description": "EventStore API client for E2E security testing (D11)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "tenants-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenants",
            "claim.name": "tenants",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        },
        {
          "name": "domains-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "domains",
            "claim.name": "domains",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        },
        {
          "name": "permissions-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "permissions",
            "claim.name": "permissions",
            "jsonType.label": "JSON",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "aggregate.attrs": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin@hexalith.io",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin-pass",
          "temporary": false
        }
      ],
      "attributes": {
        "tenants": ["tenant-a", "tenant-b"],
        "domains": ["orders", "inventory"],
        "permissions": ["command:submit", "command:replay", "command:query"]
      }
    },
    {
      "username": "tenant-a-user",
      "enabled": true,
      "email": "tenant-a@hexalith.io",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "tenant-a-pass",
          "temporary": false
        }
      ],
      "attributes": {
        "tenants": ["tenant-a"],
        "domains": ["orders"],
        "permissions": ["command:submit", "command:query"]
      }
    },
    {
      "username": "tenant-b-user",
      "enabled": true,
      "email": "tenant-b@hexalith.io",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "tenant-b-pass",
          "temporary": false
        }
      ],
      "attributes": {
        "tenants": ["tenant-b"],
        "domains": ["inventory"],
        "permissions": ["command:submit"]
      }
    },
    {
      "username": "readonly-user",
      "enabled": true,
      "email": "readonly@hexalith.io",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "readonly-pass",
          "temporary": false
        }
      ],
      "attributes": {
        "tenants": ["tenant-a"],
        "domains": ["orders"],
        "permissions": ["command:query"]
      }
    },
    {
      "username": "no-tenant-user",
      "enabled": true,
      "email": "no-tenant@hexalith.io",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "no-tenant-pass",
          "temporary": false
        }
      ],
      "attributes": {
        "tenants": [],
        "domains": ["orders"],
        "permissions": ["command:submit"]
      }
    }
  ]
}
