<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Domain-service host SDK for the Hexalith event store. A domain module references this package and writes only its domain code plus a two-line host (AddEventStoreDomainService / UseEventStoreDomainService) — all hosting, DAPR-endpoint, observability, and discovery boilerplate is provided here.</Description>
    <!--
      Publishable as the domain-service SDK (Epic A6). It references Hexalith.EventStore.ServiceDefaults, which
      is now also packable, so the produced package has a valid dependency graph. The Sample and the
      Hexalith.Tenants submodule still consume it via project references (the repository and its submodules
      build from source); external domains consume the NuGet package once the release pipeline includes it.
    -->
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapr.AspNetCore" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Hexalith.EventStore.Client\Hexalith.EventStore.Client.csproj" />
    <ProjectReference Include="..\Hexalith.EventStore.ServiceDefaults\Hexalith.EventStore.ServiceDefaults.csproj" />
  </ItemGroup>

</Project>
