    private async Task OnRestoreConfirm()
    {
        if (_restoreTarget is null) return;

        _isOperating = true;
        StateHasChanged();
        _operationCts?.Cancel();
        _operationCts?.Dispose();
        _operationCts = new CancellationTokenSource();
        try
        {
            DateTimeOffset? pointInTime = null;
            if (!string.IsNullOrWhiteSpace(_restorePointInTime))
            {
                if (DateTimeOffset.TryParse(_restorePointInTime, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out DateTimeOffset parsed))
                {
                    if (parsed > DateTimeOffset.UtcNow)
                    {
                        _restorePointInTimeError = "Point-in-time cannot be in the future.";
                        _isOperating = false;
                        StateHasChanged();
                        return;
                    }

                    pointInTime = parsed;
                    _restorePointInTimeError = null;
                }
                else
                {
                    _restorePointInTimeError = "Invalid date format. Use ISO 8601 (e.g. 2026-03-20T14:30:00Z).";
                    _isOperating = false;
                    StateHasChanged();
                    return;
                }
            }

            _restorePointInTimeError = null;

            AdminOperationResult? result = await BackupApi.TriggerRestoreAsync(
                _restoreTarget.BackupId,
                pointInTime,
                _restoreDryRun,
                _operationCts.Token);

            if (result?.Success == true)
            {
                ToastService.ShowSuccess($"Restore initiated from backup {TruncateId(_restoreTarget.BackupId)}.");
                if (_restoreDialog is not null) { await _restoreDialog.HideAsync().ConfigureAwait(false); }
                _showRestoreDialog = false;
