    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        _importError = null;
        _importPreview = null;
        _importContent = null;
        _importTenantId = null;

        try
        {
            using System.IO.Stream stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using System.IO.StreamReader reader = new(stream);
            string content = await reader.ReadToEndAsync();

            // Try to parse for preview
            try
            {
                using System.Text.Json.JsonDocument doc = System.Text.Json.JsonDocument.Parse(content);
                System.Text.Json.JsonElement root = doc.RootElement;
                string? tenantId = root.TryGetProperty("TenantId", out System.Text.Json.JsonElement tid) ? tid.GetString() : null;
                string? domain = root.TryGetProperty("Domain", out System.Text.Json.JsonElement dom) ? dom.GetString() : null;
                string? aggregateId = root.TryGetProperty("AggregateId", out System.Text.Json.JsonElement aid) ? aid.GetString() : null;
                int eventCount = root.TryGetProperty("Events", out System.Text.Json.JsonElement evts) && evts.ValueKind == System.Text.Json.JsonValueKind.Array
                    ? evts.GetArrayLength()
                    : 0;

                if (tenantId is null || domain is null || aggregateId is null)
                {
                    _importError = "Invalid export file format. Expected JSON with TenantId, Domain, AggregateId, and Events array.";
                    return;
                }

                _importTenantId = tenantId;
                _importContent = content;
                _importPreview = $"Tenant: {tenantId}\nDomain: {domain}\nAggregate: {aggregateId}\nEvents: {eventCount}";
            }
            catch (System.Text.Json.JsonException)
            {
                _importError = "Invalid export file format. Expected JSON with TenantId, Domain, AggregateId, and Events array.";
            }
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _importError = $"Failed to read file: {ex.Message}";
        }
    }

