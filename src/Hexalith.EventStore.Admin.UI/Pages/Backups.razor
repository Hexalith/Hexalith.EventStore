        }
        catch (ServiceUnavailableException)
        {
            ToastService.ShowError("Admin service unavailable. Try again later.");
        }
        catch (OperationCanceledException)
        {
            // Silently handle cancellation
        }
        finally
        {
            _isOperating = false;
            StateHasChanged();
        }
    }

