@page "/streams/{TenantId}/{Domain}/{AggregateId}"

<PageTitle>Stream Detail - Hexalith EventStore Admin</PageTitle>

<h1>Stream Detail</h1>

<EmptyState Title="Stream detail view coming in story 15-3."
