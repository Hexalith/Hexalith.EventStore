    private void UpdateUrl()
    {
        List<string> queryParams = [];
        if (_fromSequence.HasValue)
        {
            queryParams.Add($"from={_fromSequence.Value}");
        }

        if (_toSequence.HasValue)
        {
            queryParams.Add($"to={_toSequence.Value}");
        }

        if (_selectedEntryType.HasValue)
        {
            queryParams.Add($"type={_selectedEntryType.Value.ToString().ToLowerInvariant()}");
        }

        if (!string.IsNullOrEmpty(_correlationFilter))
        {
            queryParams.Add($"correlation={Uri.EscapeDataString(_correlationFilter)}");
        }

        if (_sandboxMode)
        {
            if (_sandboxSequence.HasValue)
            {
                queryParams.Add($"sandbox={_sandboxSequence.Value}");
            }
            else
            {
                queryParams.Add("sandbox=true");
            }
        }
        else if (_traceMode && !string.IsNullOrEmpty(_traceCorrelationId))
        {
            queryParams.Add($"trace={Uri.EscapeDataString(_traceCorrelationId)}");
        }
        else if (_stepMode && _stepSequence.HasValue)
        {
            queryParams.Add($"step={_stepSequence.Value}");
        }
        else if (_bisectMode && _bisectGood.HasValue && _bisectBad.HasValue)
        {
            queryParams.Add($"bisect={_bisectGood.Value}-{_bisectBad.Value}");
        }
        else if (_blameMode)
        {
            if (_blameSequence.HasValue)
            {
                queryParams.Add($"blame={_blameSequence.Value}");
            }
            else
            {
                queryParams.Add("blame=latest");
            }
        }
        else if (_diffMode)
        {
            queryParams.Add($"diff={_diffFrom}-{_diffTo}");
        }
        else if (_selectedSequence.HasValue)
        {
            queryParams.Add($"detail={_selectedSequence.Value}");
        }

        // P7: Write ?inspect= to URL for deep linking
        if (_showInspectorModal && _inspectorSequence.HasValue)
        {
            queryParams.Add($"inspect={_inspectorSequence.Value}");
        }

        string path = $"/streams/{Uri.EscapeDataString(TenantId)}/{Uri.EscapeDataString(Domain)}/{Uri.EscapeDataString(AggregateId)}";
        string url = queryParams.Count > 0 ? $"{path}?{string.Join('&', queryParams)}" : path;
        Navigation.NavigateTo(url, forceLoad: false, replace: true);
    }

    private static bool TryParseDiffParam(string diffParam, out long from, out long to)
    {
        from = 0;
        to = 0;
        string[] parts = diffParam.Split('-');
        if (parts.Length == 2 && long.TryParse(parts[0], out long a) && long.TryParse(parts[1], out long b))
        {
            from = Math.Min(a, b);
            to = Math.Max(a, b);
            return true;
        }

        return false;
    }

    private string GetStreamStatusSeverity() => _streamStatus switch
    {
        StreamStatus.Active => "success",
        StreamStatus.Tombstoned => "error",
        _ => "neutral",
    };

    private static string FormatRelativeTime(DateTimeOffset? timestamp)
    {
        if (!timestamp.HasValue)
        {
            return "\u2014";
        }

        TimeSpan elapsed = DateTimeOffset.UtcNow - timestamp.Value;
        if (elapsed.TotalSeconds < 0)
        {
            return "Just now";
        }

        if (elapsed.TotalMinutes < 1)
        {
            return "Just now";
        }

        if (elapsed.TotalMinutes < 60)
        {
            return $"{(int)elapsed.TotalMinutes}m ago";
        }

        if (elapsed.TotalHours < 24)
        {
            return $"{(int)elapsed.TotalHours}h ago";
        }

        return $"{(int)elapsed.TotalDays}d ago";
    }

