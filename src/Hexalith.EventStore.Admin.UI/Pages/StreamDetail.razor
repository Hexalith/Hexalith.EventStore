@page "/streams/{TenantId}/{Domain}/{AggregateId}"
@namespace Hexalith.EventStore.Admin.UI.Pages
@using Hexalith.EventStore.Admin.Abstractions.Models.Streams
@using Hexalith.EventStore.Admin.UI.Services
@using static Hexalith.EventStore.Admin.UI.Components.Shared.StatusBadge
@implements IAsyncDisposable
@inject AdminStreamApiClient ApiClient
@inject DashboardRefreshService RefreshService
@inject ViewportService Viewport
@inject NavigationManager Navigation

<PageTitle>Stream @AggregateId - Hexalith EventStore</PageTitle>

<nav class="admin-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="separator" aria-hidden="true">/</span>
    <a href="/streams">Streams</a>
    <span class="separator" aria-hidden="true">/</span>
    <a href="@($"/streams?tenant={Uri.EscapeDataString(TenantId)}")">@TenantId</a>
    <span class="separator" aria-hidden="true">/</span>
    <a href="@($"/streams?tenant={Uri.EscapeDataString(TenantId)}&domain={Uri.EscapeDataString(Domain)}")">@Domain</a>
    <span class="separator" aria-hidden="true">/</span>
    <span class="current">@AggregateId</span>
</nav>

@if (_loading)
{
    <div class="stat-card-grid" style="margin: 16px 0;">
        <SkeletonCard />
        <SkeletonCard />
        <SkeletonCard />
        <SkeletonCard />
    </div>
    <p>Loading stream...</p>
}
else if (_error is not null)
{
    <EmptyState Title="Unable to load timeline. Check Admin API connection."
                Description="@_error"
                ActionLabel="Retry"
                ActionHref="@Navigation.Uri" />
}
else
{
    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center"
                 Style="margin: 16px 0 8px 0;">
        <h1 style="margin: 0; font-size: 20px;">
            <span class="monospace">@TenantId / @Domain / @AggregateId</span>
            <FluentButton Appearance="ButtonAppearance.Transparent"
                          Title="Copy stream key"
                          OnClick="@CopyStreamKey"
                          aria-label="Copy stream key to clipboard"
                          Style="margin-left: 4px;">
                &#x1F4CB;
            </FluentButton>
        </h1>
        @if (_streamStatus.HasValue)
        {
            <StatusBadge DisplayConfig="@StatusDisplayConfig.FromStreamStatus(_streamStatus.Value)"
                         AriaLabelPrefix="Stream status" />
        }
    </FluentStack>

    <div class="stat-card-grid" style="margin-bottom: 16px;">
        <StatCard Label="Event Count" Value="@_eventCount.ToString()" />
        <StatCard Label="Last Activity" Value="@FormatRelativeTime(_lastActivity)"
                  Title="@(_lastActivity?.ToString("yyyy-MM-dd HH:mm:ss.fff zzz"))" />
        <StatCard Label="Stream Status" Value="@(_streamStatus?.ToString() ?? "Unknown")"
                  Severity="@GetStreamStatusSeverity()" />
        <StatCard Label="Has Snapshot" Value="@(_hasSnapshot ? "Yes" : "No")" />
    </div>

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-bottom: 8px;">
        <FluentButton Appearance="ButtonAppearance.Outline"
                      OnClick="@OpenBlameViewer"
                      Icon="@(new Icons.Regular.Size20.PersonSearch())"
                      aria-label="Open blame view"
                      Title="Show per-field provenance">
            Blame
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline"
                      OnClick="@OpenBisectTool"
                      Icon="@(new Icons.Regular.Size20.BranchCompare())"
                      aria-label="Open bisect tool"
                      Title="Binary search for state divergence">
            Bisect
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline"
                      OnClick="@OpenStepDebugger"
                      Icon="@(new Icons.Regular.Size20.PlayCircle())"
                      aria-label="Open step-through debugger"
                      Title="Step through events with state changes">
            Step Through
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline"
                      OnClick="@OpenSandbox"
                      Icon="@(new Icons.Regular.Size20.BeakerSettings())"
                      aria-label="Open command sandbox"
                      Title="Test a command as dry run">
            Sandbox
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline"
                      OnClick="@OpenTraceMap"
                      Icon="@(new Icons.Regular.Size20.BranchFork())"
                      Disabled="@(!_selectedSequence.HasValue)"
                      aria-label="Open trace map"
                      Title="@(_selectedSequence.HasValue ? "Trace correlation ID for selected event" : "Select an event to trace its correlation ID")">
            Trace Map
        </FluentButton>
    </FluentStack>

    <TimelineFilterBar @bind-SelectedEntryType="_selectedEntryType"
                       @bind-SelectedEntryType:after="OnFilterChanged"
                       @bind-CorrelationFilter="_correlationFilter"
                       @bind-CorrelationFilter:after="OnFilterChanged"
                       @bind-CompareMode="_compareMode"
                       @bind-CompareMode:after="OnCompareModeChanged" />

    @if (_sandboxMode)
    {
        @* Command sandbox replaces the detail panel *@
        <div style="margin-top: 16px;">
            <CommandSandbox TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                            InitialSequence="@_sandboxSequence"
                            OnClose="CloseSandbox"
                            OnNavigateToEvent="OnSandboxNavigateToEvent" />
        </div>
    }
    else if (_traceMode && !string.IsNullOrEmpty(_traceCorrelationId))
    {
        @* Correlation trace map replaces the detail panel *@
        <div style="margin-top: 16px;">
            <CorrelationTraceMap TenantId="@TenantId"
                                CorrelationId="@_traceCorrelationId"
                                Domain="@Domain"
                                AggregateId="@AggregateId"
                                OnClose="CloseTraceMap"
                                OnNavigateToEvent="OnTraceNavigateToEvent" />
        </div>
    }
    else if (_stepMode)
    {
        @* Step-through debugger replaces the detail panel *@
        <div style="margin-top: 16px;">
            <EventDebugger TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                           InitialSequence="@_stepSequence"
                           OnClose="CloseStepDebugger"
                           OnNavigateToEvent="OnStepNavigateToEvent"
                           OnNavigateToBlame="@(new EventCallback<long>(this, OnStepNavigateToBlame))"
                           OnNavigateToBisect="@(new EventCallback<(long, long)>(this, OnStepNavigateToBisect))"
                           OnSequenceChanged="OnStepSequenceChanged" />
        </div>
    }
    else if (_bisectMode)
    {
        @* Bisect tool replaces the detail panel *@
        <div style="margin-top: 16px;" @onkeydown="OnDetailKeyDown">
            <BisectTool TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                        InitialGoodSequence="@_bisectGood"
                        InitialBadSequence="@_bisectBad"
                        OnClose="CloseBisectTool"
                        OnNavigateToEvent="OnBisectNavigateToEvent"
                        OnNavigateToBlame="OnBisectNavigateToBlame" />
        </div>
    }
    else if (_blameMode)
    {
        @* Blame viewer replaces the detail panel *@
        <div style="margin-top: 16px;" @onkeydown="OnDetailKeyDown">
            <BlameViewer TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                         AtSequence="@_blameSequence"
                         OnClose="CloseBlameViewer"
                         OnNavigateToEvent="OnBlameNavigateToEvent" />
        </div>
    }
    else if (_diffMode)
    {
        @* Diff viewer replaces the detail panel *@
        <div style="margin-top: 16px;" @onkeydown="OnDetailKeyDown">
            <StateDiffViewer TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                             FromSequence="@_diffFrom" ToSequence="@_diffTo"
                             OnClose="CloseDiffViewer" />
        </div>
    }
    else if (_selectedSequence.HasValue && !Viewport.IsWideViewport)
    {
        <div style="margin-top: 16px;" @onkeydown="OnDetailKeyDown">
            <FluentButton Appearance="ButtonAppearance.Outline"
                          OnClick="@CloseDetailPanel"
                          aria-label="Close detail panel">
                &#x2190; Back to timeline
            </FluentButton>
            <div style="margin-top: 8px;" role="complementary" aria-label="Timeline entry detail">
                @RenderDetailPanel()
            </div>
        </div>
    }
    else if (_selectedSequence.HasValue && Viewport.IsWideViewport)
    {
        <div style="margin-top: 16px; display: flex; gap: 16px; min-height: 500px;" @onkeydown="OnDetailKeyDown">
            <div style="flex: 6;">
                @RenderTimelineGrid()
            </div>
            <div style="flex: 4; border-left: 1px solid var(--neutral-stroke-divider-rest); padding-left: 16px;">
                <FluentButton Appearance="ButtonAppearance.Transparent" OnClick="@CloseDetailPanel"
                              aria-label="Close detail panel" Title="Close" Style="margin-bottom: 8px;">
                    &#x2716;
                </FluentButton>
                <div role="complementary" aria-label="Timeline entry detail">
                    @RenderDetailPanel()
                </div>
            </div>
        </div>
    }
    else
    {
        <div style="margin-top: 16px;">
            @RenderTimelineGrid()
        </div>
    }

    @if (_showInspectorModal)
    {
        <StateInspectorModal TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                             InitialSequenceNumber="@_inspectorSequence"
                             OnClose="CloseInspectorModal" />
    }
}

@code {
    private const int PageSize = 50;
    private const int FilteredPageSize = 500;

    private bool _loading = true;
    private bool _disposed;
    private string? _error;

    private long _eventCount;
    private DateTimeOffset? _lastActivity;
    private StreamStatus? _streamStatus;
    private bool _hasSnapshot = false;
    private HashSet<long> _previousSequenceNumbers = [];

    private List<TimelineEntry> _timelineEntries = [];
    private int _totalCount;
    private long? _fromSequence;
    private long? _toSequence;

    private TimelineEntryType? _selectedEntryType;
    private string? _correlationFilter;

    private long? _selectedSequence;
    private TimelineEntry? _selectedEntry;

    // Compare mode state
    private bool _compareMode;

    // Diff viewer state
    private bool _diffMode;
    private long _diffFrom;
    private long _diffTo;

    // Blame viewer state
    private bool _blameMode;
    private long? _blameSequence;

    // Bisect tool state
    private bool _bisectMode;
    private long? _bisectGood;
    private long? _bisectBad;

    // Step debugger state
    private bool _stepMode;
    private long? _stepSequence;

    // Sandbox state
    private bool _sandboxMode;
    private long? _sandboxSequence;

    // Trace map state
    private bool _traceMode;
    private string? _traceCorrelationId;

    // Inspector modal state
    private bool _showInspectorModal;
    private long? _inspectorSequence;

    [Parameter]
    public string TenantId { get; set; } = string.Empty;

    [Parameter]
    public string Domain { get; set; } = string.Empty;

    [Parameter]
    public string AggregateId { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "from")]
    public long? QueryFrom { get; set; }

    [SupplyParameterFromQuery(Name = "to")]
    public long? QueryTo { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    public string? QueryType { get; set; }

    [SupplyParameterFromQuery(Name = "correlation")]
    public string? QueryCorrelation { get; set; }

    [SupplyParameterFromQuery(Name = "detail")]
    public long? QueryDetail { get; set; }

    [SupplyParameterFromQuery(Name = "view")]
    public string? QueryView { get; set; }

    [SupplyParameterFromQuery(Name = "diff")]
    public string? QueryDiff { get; set; }

    [SupplyParameterFromQuery(Name = "inspect")]
    public long? QueryInspect { get; set; }

    [SupplyParameterFromQuery(Name = "blame")]
    public string? QueryBlame { get; set; }

    [SupplyParameterFromQuery(Name = "bisect")]
    public string? QueryBisect { get; set; }

    [SupplyParameterFromQuery(Name = "step")]
    public long? QueryStep { get; set; }

    [SupplyParameterFromQuery(Name = "sandbox")]
    public string? QuerySandbox { get; set; }

    [SupplyParameterFromQuery(Name = "trace")]
    public string? QueryTrace { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _fromSequence = QueryFrom;
        _toSequence = QueryTo;
        _correlationFilter = QueryCorrelation;
        _selectedSequence = QueryDetail;

        if (!string.IsNullOrEmpty(QueryType) && Enum.TryParse<TimelineEntryType>(QueryType, true, out TimelineEntryType t))
        {
            _selectedEntryType = t;
        }

        // Parse deep links with precedence: sandbox > trace > step > bisect > blame > diff
        if (!string.IsNullOrEmpty(QuerySandbox))
        {
            _sandboxMode = true;
            _sandboxSequence = long.TryParse(QuerySandbox, out long sandboxSeq) ? sandboxSeq : null;
        }
        else if (!string.IsNullOrEmpty(QueryTrace))
        {
            _traceMode = true;
            _traceCorrelationId = QueryTrace;
        }
        else if (QueryStep.HasValue && QueryStep.Value >= 1)
        {
            _stepMode = true;
            _stepSequence = QueryStep.Value;
        }
        else if (!string.IsNullOrEmpty(QueryBisect) && TryParseDiffParam(QueryBisect, out long bisectGood, out long bisectBad))
        {
            _bisectMode = true;
            _bisectGood = bisectGood;
            _bisectBad = bisectBad;
        }
        else if (!string.IsNullOrEmpty(QueryBlame))
        {
            _blameMode = true;
            _blameSequence = long.TryParse(QueryBlame, out long blameSeq) ? blameSeq : null;
        }
        // Parse ?diff=5-15 deep link (normalized: Min-Max) — only if bisect and blame are not active
        else if (!string.IsNullOrEmpty(QueryDiff) && TryParseDiffParam(QueryDiff, out long diffFrom, out long diffTo))
        {
            _diffMode = true;
            _diffFrom = diffFrom;
            _diffTo = diffTo;
        }

        // Parse ?inspect=42 deep link
        if (QueryInspect.HasValue)
        {
            _showInspectorModal = true;
            _inspectorSequence = QueryInspect.Value;
        }

        RefreshService.OnDataChanged += OnDataChanged;
        Viewport.OnViewportChanged += OnViewportChanged;
        await Viewport.InitializeAsync();
        await LoadTimelineAsync();
    }

    private RenderFragment RenderTimelineGrid() => __builder =>
    {
        <StreamTimelineGrid Entries="@_timelineEntries" TotalCount="@_totalCount" PageSize="@PageSize"
                             CanNavigateNewer="@(_fromSequence is not null || _toSequence is not null)"
                             CanNavigateOlder="@(_timelineEntries.Count >= PageSize)"
                             OnNavigateNewer="@NavigateNewer" OnNavigateOlder="@NavigateOlder"
                             OnRowClick="@SelectEntry"
                             CompareMode="@_compareMode"
                             OnCompareRequested="@OnCompareRequested" />
    };

    private RenderFragment RenderDetailPanel() => __builder =>
    {
        if (_selectedEntry?.EntryType == TimelineEntryType.Event)
        {
            <EventDetailPanel TenantId="@TenantId" Domain="@Domain" AggregateId="@AggregateId"
                              SequenceNumber="@_selectedEntry.SequenceNumber"
                              OnCopyCorrelation="@OpenTraceMapForCorrelation"
                              OnInspectState="@OnInspectStateFromDetail"
                              OnDiffRequested="@OnDiffFromDetail"
                              AutoTraceCausation="@(QueryView == "causation")" />
        }
        else if (_selectedEntry?.EntryType == TimelineEntryType.Command)
        {
            <CommandDetailPanel Entry="@_selectedEntry" OnCorrelationFilter="@OpenTraceMapForCorrelation" />
        }
    };

    private async Task LoadTimelineAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            bool hasFilters = _selectedEntryType.HasValue || !string.IsNullOrEmpty(_correlationFilter);
            int count = hasFilters ? FilteredPageSize : PageSize;

            PagedResult<TimelineEntry> result = await ApiClient.GetStreamTimelineAsync(
                TenantId, Domain, AggregateId, _fromSequence, _toSequence, count);

            _totalCount = result.TotalCount;

            if (result.Items.Count > 0)
            {
                _lastActivity = result.Items.Max(e => e.Timestamp);
                _eventCount = _totalCount;
                _streamStatus = StreamStatus.Active;
            }

            IEnumerable<TimelineEntry> filtered = result.Items;
            if (_selectedEntryType.HasValue)
            {
                filtered = filtered.Where(e => e.EntryType == _selectedEntryType.Value);
            }

            if (!string.IsNullOrEmpty(_correlationFilter))
            {
                filtered = filtered.Where(e =>
                    e.CorrelationId is not null &&
                    e.CorrelationId.StartsWith(_correlationFilter, StringComparison.OrdinalIgnoreCase));
            }

            _timelineEntries = filtered.OrderByDescending(e => e.SequenceNumber).ToList();
            _previousSequenceNumbers = _timelineEntries.Select(e => e.SequenceNumber).ToHashSet();

            if (_selectedSequence.HasValue)
            {
                _selectedEntry = _timelineEntries
                    .FirstOrDefault(e => e.SequenceNumber == _selectedSequence.Value);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async void OnDataChanged(DashboardData data)
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(async () =>
            {
                await LoadTimelineAsync();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
            // Component disposed during async callback
        }
        catch (Exception)
        {
            // Refresh failed — keep stale data, don't crash
        }
    }

    private void OnViewportChanged()
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Component disposed
        }
    }

    private async Task OnFilterChanged()
    {
        _fromSequence = null;
        _toSequence = null;
        UpdateUrl();
        await LoadTimelineAsync();
    }

    private async Task NavigateOlder()
    {
        if (_timelineEntries.Count > 0)
        {
            long minSeq = _timelineEntries.Min(e => e.SequenceNumber);
            _toSequence = minSeq > 0 ? minSeq - 1 : 0;
            _fromSequence = null;
            UpdateUrl();
            await LoadTimelineAsync();
        }
    }

    private async Task NavigateNewer()
    {
        if (_timelineEntries.Count > 0)
        {
            long maxSeq = _timelineEntries.Max(e => e.SequenceNumber);
            _fromSequence = maxSeq + 1;
            _toSequence = null;
            UpdateUrl();
            await LoadTimelineAsync();
        }
    }

    private void SelectEntry(TimelineEntry entry)
    {
        if (_selectedSequence == entry.SequenceNumber)
        {
            CloseDetailPanel();
            return;
        }

        _diffMode = false;
        _selectedSequence = entry.SequenceNumber;
        _selectedEntry = entry;
        UpdateUrl();
    }

    private void CloseDetailPanel()
    {
        _selectedSequence = null;
        _selectedEntry = null;
        _diffMode = false;
        UpdateUrl();
    }

    private void CloseDiffViewer()
    {
        _diffMode = false;
        UpdateUrl();
    }

    private void OpenBlameViewer()
    {
        _blameMode = true;
        _blameSequence = _selectedSequence; // null means latest
        _diffMode = false;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void CloseBlameViewer()
    {
        _blameMode = false;
        _blameSequence = null;
        UpdateUrl();
    }

    private void OnBlameNavigateToEvent(long sequenceNumber)
    {
        _blameMode = false;
        _blameSequence = null;
        _selectedSequence = sequenceNumber;
        _selectedEntry = _timelineEntries
            .FirstOrDefault(e => e.SequenceNumber == sequenceNumber);
        UpdateUrl();
    }

    private void OpenBisectTool()
    {
        _bisectMode = true;
        // If an event is selected, pre-fill bad with that sequence and good with 0
        if (_selectedSequence.HasValue)
        {
            _bisectBad = _selectedSequence.Value;
            _bisectGood = 0;
        }
        else
        {
            _bisectGood = null;
            _bisectBad = null;
        }

        _blameMode = false;
        _diffMode = false;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void CloseBisectTool()
    {
        _bisectMode = false;
        _bisectGood = null;
        _bisectBad = null;
        UpdateUrl();
    }

    private void OnBisectNavigateToEvent(long sequenceNumber)
    {
        _bisectMode = false;
        _bisectGood = null;
        _bisectBad = null;
        _selectedSequence = sequenceNumber;
        _selectedEntry = _timelineEntries
            .FirstOrDefault(e => e.SequenceNumber == sequenceNumber);
        UpdateUrl();
    }

    private void OnBisectNavigateToBlame(long sequenceNumber)
    {
        _bisectMode = false;
        _bisectGood = null;
        _bisectBad = null;
        _blameMode = true;
        _blameSequence = sequenceNumber;
        UpdateUrl();
    }

    private void OpenStepDebugger()
    {
        _stepMode = true;
        _stepSequence = _selectedSequence ?? 1;
        _bisectMode = false;
        _blameMode = false;
        _diffMode = false;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void CloseStepDebugger()
    {
        _stepMode = false;
        _stepSequence = null;
        UpdateUrl();
    }

    private void OnStepNavigateToEvent(long sequenceNumber)
    {
        _stepMode = false;
        _stepSequence = null;
        _selectedSequence = sequenceNumber;
        _selectedEntry = _timelineEntries
            .FirstOrDefault(e => e.SequenceNumber == sequenceNumber);
        UpdateUrl();
    }

    private void OnStepNavigateToBlame(long sequenceNumber)
    {
        _stepMode = false;
        _stepSequence = null;
        _blameMode = true;
        _blameSequence = sequenceNumber;
        UpdateUrl();
    }

    private void OnStepNavigateToBisect((long Good, long Bad) range)
    {
        _stepMode = false;
        _stepSequence = null;
        _bisectMode = true;
        _bisectGood = range.Good;
        _bisectBad = range.Bad;
        UpdateUrl();
    }

    private void OnStepSequenceChanged(long sequenceNumber)
    {
        _stepSequence = sequenceNumber;
        UpdateUrl();
    }

    private void OpenSandbox()
    {
        _sandboxMode = true;
        _sandboxSequence = _selectedSequence; // null means latest
        _stepMode = false;
        _bisectMode = false;
        _blameMode = false;
        _diffMode = false;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void CloseSandbox()
    {
        _sandboxMode = false;
        _sandboxSequence = null;
        UpdateUrl();
    }

    private void OnSandboxNavigateToEvent(long sequenceNumber)
    {
        _sandboxMode = false;
        _sandboxSequence = null;
        _selectedSequence = sequenceNumber;
        _selectedEntry = _timelineEntries
            .FirstOrDefault(e => e.SequenceNumber == sequenceNumber);
        UpdateUrl();
    }

    private void OpenTraceMap()
    {
        if (_selectedEntry is null)
        {
            return;
        }

        _traceMode = true;
        _traceCorrelationId = _selectedEntry.CorrelationId;
        _sandboxMode = false;
        _stepMode = false;
        _bisectMode = false;
        _blameMode = false;
        _diffMode = false;
        UpdateUrl();
    }

    private void OpenTraceMapForCorrelation(string correlationId)
    {
        _traceMode = true;
        _traceCorrelationId = correlationId;
        _sandboxMode = false;
        _stepMode = false;
        _bisectMode = false;
        _blameMode = false;
        _diffMode = false;
        UpdateUrl();
    }

    private void CloseTraceMap()
    {
        _traceMode = false;
        _traceCorrelationId = null;
        UpdateUrl();
    }

    private void OnTraceNavigateToEvent(long sequenceNumber)
    {
        _traceMode = false;
        _traceCorrelationId = null;
        _selectedSequence = sequenceNumber;
        _selectedEntry = _timelineEntries
            .FirstOrDefault(e => e.SequenceNumber == sequenceNumber);
        UpdateUrl();
    }

    private void OnCompareModeChanged()
    {
        if (!_compareMode)
        {
            _diffMode = false;
        }
    }

    private void OnCompareRequested((long From, long To) compare)
    {
        _diffMode = true;
        _diffFrom = compare.From;
        _diffTo = compare.To;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void OnInspectStateFromDetail(long sequenceNumber)
    {
        _showInspectorModal = true;
        _inspectorSequence = sequenceNumber;
        UpdateUrl();
    }

    private void OnDiffFromDetail((long From, long To) diff)
    {
        _diffMode = true;
        _diffFrom = diff.From;
        _diffTo = diff.To;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
    }

    private void CloseInspectorModal()
    {
        _showInspectorModal = false;
        _inspectorSequence = null;
        UpdateUrl();
    }

    private async Task OnCorrelationFilterFromDetail(string correlationId)
    {
        _correlationFilter = correlationId;
        _selectedSequence = null;
        _selectedEntry = null;
        UpdateUrl();
        await LoadTimelineAsync();
    }

    private void OnDetailKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            if (_sandboxMode)
            {
                CloseSandbox();
            }
            else if (_traceMode)
            {
                CloseTraceMap();
            }
            else if (_stepMode)
            {
                CloseStepDebugger();
            }
            else if (_bisectMode)
            {
                CloseBisectTool();
            }
            else if (_blameMode)
            {
                CloseBlameViewer();
            }
            else if (_diffMode)
            {
                CloseDiffViewer();
            }
            else
            {
                CloseDetailPanel();
            }
        }
    }

