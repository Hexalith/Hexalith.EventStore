@page "/dapr"

@using Hexalith.EventStore.Admin.Abstractions.Models.Dapr
@using Hexalith.EventStore.Admin.Abstractions.Models.Health
@using Hexalith.EventStore.Admin.UI.Components.Shared
@using Hexalith.EventStore.Admin.UI.Services

@implements IAsyncDisposable

@inject AdminDaprApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ILogger<DaprComponents> Logger

<PageTitle>DAPR - Hexalith EventStore</PageTitle>

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
    <h1 style="margin: 0;">DAPR Infrastructure</h1>
    <div style="display: flex; gap: 8px;">
        <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                      OnClick="@(() => NavigationManager.NavigateTo("/dapr/actors"))"
                      aria-label="Open Actor Inspector">
            Actor Inspector
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                      OnClick="@(() => NavigationManager.NavigateTo("/dapr/pubsub"))"
                      aria-label="Open Pub/Sub Metrics">
            Pub/Sub Metrics
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                      OnClick="@(() => NavigationManager.NavigateTo("/dapr/resiliency"))"
                      aria-label="Open Resiliency Policies">
            Resiliency Policies
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                      OnClick="@(() => NavigationManager.NavigateTo("/dapr/health-history"))"
                      aria-label="Open Health History">
            Health History
        </FluentButton>
        <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                      OnClick="OnManualRefresh"
                      aria-label="Refresh DAPR dashboard">
            Refresh
        </FluentButton>
    </div>
</div>

@* Error state: API unavailable and no cached data *@
<IssueBanner Visible="@(_apiUnavailable && _cachedSidecar is null)"
             Title="Unable to load DAPR infrastructure"
             Description="The admin backend service may be unavailable. Check DAPR sidecar connectivity."
             ActionLabel="Retry"
             OnAction="LoadDataAsync" />

@* Stale data indicator *@
<IssueBanner Visible="@(_isStale && _cachedSidecar is not null)"
             Title="@_staleBannerTitle"
             Description="" />

@* Sidecar stat cards (AC1) *@
<FluentGrid Spacing="3" style="margin-bottom: 16px;">
    @if (_isLoading)
    {
        <FluentGridItem xs="6" sm="6" md="3">
            <SkeletonCard />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <SkeletonCard />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <SkeletonCard />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <SkeletonCard />
        </FluentGridItem>
    }
    else if (_sidecar is not null)
    {
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="App ID"
                      Value="@_sidecar.AppId"
                      Severity="neutral"
                      Title="DAPR sidecar app ID" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Runtime Version"
                      Value="@_sidecar.RuntimeVersion"
                      Severity="neutral"
                      Title="DAPR runtime version" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Components"
                      Value="@_components.Count.ToString()"
                      Severity="@GetComponentsCountSeverity()"
                      Subtitle="@GetComponentsCountSubtitle()"
                      Title="Number of components in the canonical inventory (merged remote + local)" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Active Subscriptions"
                      Value="@(_sidecar.RemoteMetadataStatus == RemoteMetadataStatus.Available ? _sidecar.SubscriptionCount.ToString() : "subscription data unavailable")"
                      Severity="@(_sidecar.RemoteMetadataStatus == RemoteMetadataStatus.Available ? "neutral" : "warning")"
                      Subtitle="@(_sidecar.RemoteMetadataStatus == RemoteMetadataStatus.Available ? $"{_sidecar.HttpEndpointCount} HTTP endpoints" : "HTTP endpoints: unavailable")"
                      Title="@GetRemoteMetadataTitle(_sidecar)" />
        </FluentGridItem>
    }
</FluentGrid>

@* Empty state (AC9) — copy mirrors DaprPubSub.razor by RemoteMetadataStatus *@
@if (!_isLoading && _components.Count == 0 && !_apiUnavailable)
{
    @switch (_sidecar?.RemoteMetadataStatus)
    {
        case RemoteMetadataStatus.NotConfigured:
            <EmptyState Title="DAPR component inventory not configured"
                        Description="Remote EventStore sidecar metadata is disabled. Set 'AdminServer:EventStoreDaprHttpEndpoint' in appsettings (under Aspire, this is wired automatically)." />
            break;
        case RemoteMetadataStatus.Unreachable:
            <EmptyState Title="EventStore sidecar unreachable"
                        Description="@($"Attempted to query {_sidecar?.RemoteEndpoint}/v1.0/metadata but the call failed. Verify the EventStore DAPR sidecar is running. Check Admin server logs for exception details.")" />
            break;
        case RemoteMetadataStatus.InvalidPayload:
            <EmptyState Title="EventStore sidecar metadata invalid"
                        Description="@($"The remote sidecar at {_sidecar?.RemoteEndpoint} responded but the metadata payload could not be parsed. Component inventory is unavailable until the sidecar returns a well-formed response.")" />
            break;
        case RemoteMetadataStatus.Available:
            // Available + zero-component grid: no inventory but the canonical source confirmed
            // the empty payload, so render an honest empty-state rather than the generic copy.
            <EmptyState Title="No DAPR components reported"
                        Description="@($"The remote sidecar at {_sidecar?.RemoteEndpoint} returned a valid metadata response with no components. If components are expected here, verify the sidecar configuration.")" />
            break;
        case null:
            <EmptyState Title="DAPR sidecar metadata unavailable"
                        Description="The Admin API did not return DAPR sidecar metadata for this view. Check Admin server logs and DAPR connectivity." />
            break;
        default:
            // Future RemoteMetadataStatus members fall here. Log a warning so the missing UI
            // translation is observable, then render a generic explanation rather than blank.
            Logger.LogWarning("Unrecognised RemoteMetadataStatus '{Status}' in DaprComponents empty state.", _sidecar?.RemoteMetadataStatus);
            <EmptyState Title="DAPR component inventory unavailable"
                        Description="@($"The remote sidecar reported an unrecognised metadata status ({_sidecar?.RemoteMetadataStatus}). Component inventory cannot be displayed.")" />
            break;
    }
}

@* Component grid (AC2, AC3, AC4, AC5) *@
@if (!_isLoading && _components.Count > 0)
{
    @* Filters (AC3) *@
    <div style="display: flex; gap: 12px; margin-bottom: 12px; flex-wrap: wrap;">
        <FluentTextInput @bind-Value="_searchFilter"
                      @bind-Value:after="OnFilterChanged"
                      Placeholder="Filter by name or type..."
                      style="min-width: 200px;"
                      aria-label="Filter components by name or type"
                      TextInputType="TextInputType.Text">
            <StartTemplate>
                <FluentIcon Value="@(new Icons.Regular.Size16.Search())" />
            </StartTemplate>
            <EndTemplate>
                <FluentButton Appearance="ButtonAppearance.Transparent"
                              Disabled="@(string.IsNullOrEmpty(_searchFilter))"
                              OnClick="ClearSearchFilter"
                              aria-label="Clear search"
                              Title="Clear search">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                </FluentButton>
            </EndTemplate>
        </FluentTextInput>
        <FluentSelect TOption="string" TValue="string"
                      Value="@_categoryFilter"
                      ValueChanged="OnCategoryFilterChanged"
                      style="min-width: 150px;"
                      aria-label="Filter by component category">
            <FluentOption Value="@string.Empty">All Categories</FluentOption>
            <FluentOption Value="@("StateStore")">State Store</FluentOption>
            <FluentOption Value="@("PubSub")">Pub/Sub</FluentOption>
            <FluentOption Value="@("Binding")">Binding</FluentOption>
            <FluentOption Value="@("Configuration")">Configuration</FluentOption>
            <FluentOption Value="@("Lock")">Lock</FluentOption>
            <FluentOption Value="@("SecretStore")">Secret Store</FluentOption>
            <FluentOption Value="@("Middleware")">Middleware</FluentOption>
        </FluentSelect>
    </div>

    <FluentDataGrid Items="@FilteredComponents" TGridItem="DaprComponentDetail"
                    Style="width: 100%; margin-bottom: 24px;"
                    aria-label="DAPR component details"
                    OnRowClick="@OnRowClick">
        <PropertyColumn Property="@(c => c.Category)" Title="Category" Sortable="true"
                        IsDefaultSortColumn="true" InitialSortDirection="DataGridSortDirection.Ascending" />
        <PropertyColumn Property="@(c => c.ComponentName)" Title="Component Name" Class="monospace" Sortable="true" />
        <PropertyColumn Property="@(c => c.ComponentType)" Title="Type" Sortable="true" />
        <PropertyColumn Property="@(c => c.Version)" Title="Version" Sortable="true" />
        <TemplateColumn Title="Source" Sortable="true"
                        SortBy="@(GridSort<DaprComponentDetail>.ByAscending(c => (int)c.Source))">
            <span title="@GetSourceTitle(context.Source)">@FormatSource(context.Source)</span>
        </TemplateColumn>
        <TemplateColumn Title="Status"
                        SortBy="@(GridSort<DaprComponentDetail>.ByDescending(c => (int)c.Status))">
            <StatusBadge Severity="@GetHealthSeverity(context.Status)"
                         Status="@context.Status.ToString()"
                         AriaLabelPrefix="Component status" />
        </TemplateColumn>
    </FluentDataGrid>

    @* Expandable detail panel (AC4) *@
    @if (_selectedComponent is not null)
    {
        <FluentCard style="margin-bottom: 24px; padding: 16px;">
            <h3 style="margin: 0 0 12px;">@_selectedComponent.ComponentName</h3>
            <div style="display: flex; gap: 24px; flex-wrap: wrap;">
                <div>
                    <strong>Type:</strong> @_selectedComponent.ComponentType
                </div>
                <div>
                    <strong>Version:</strong> @(string.IsNullOrEmpty(_selectedComponent.Version) ? "N/A" : _selectedComponent.Version)
                </div>
                <div>
                    <strong>Category:</strong> @_selectedComponent.Category
                </div>
            </div>
            @if (_selectedComponent.Capabilities.Count > 0)
            {
                <div style="margin-top: 12px;">
                    <strong>Capabilities:</strong>
                    <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;">
                        @foreach (string cap in _selectedComponent.Capabilities)
                        {
                            <FluentBadge Appearance="BadgeAppearance.Filled" Content="@cap" />
                        }
                    </div>
                </div>
            }
            else
            {
                <div style="margin-top: 12px;">
                    <strong>Capabilities:</strong> <span style="color: var(--colorNeutralForeground3);">None reported</span>
                </div>
            }
            <div style="margin-top: 12px;">
                <strong>Scopes:</strong> <span style="color: var(--colorNeutralForeground3);">All (no scope restriction)</span>
            </div>
        </FluentCard>
    }
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private bool _isLoading = true;
    private bool _apiUnavailable;
    private bool _isStale;
    private DaprSidecarInfo? _sidecar;
    private DaprSidecarInfo? _cachedSidecar;
    private IReadOnlyList<DaprComponentDetail> _components = [];
    private DaprComponentDetail? _selectedComponent;
    private DateTimeOffset _lastRefreshUtc;
    private string? _searchFilter = string.Empty;
    private string _categoryFilter = string.Empty;

    /// <summary>
    /// Gets or sets the component type filter from query string (AC10).
    /// </summary>
    [SupplyParameterFromQuery(Name = "type")]
    public string? Type { get; set; }

    private string _staleBannerTitle => $"DAPR data may be stale \u2014 last updated {FormatTimeAgo(_lastRefreshUtc)}";

    private static readonly Dictionary<string, DaprComponentCategory> _typeMapping = new(StringComparer.OrdinalIgnoreCase)
    {
        ["state"] = DaprComponentCategory.StateStore,
        ["pubsub"] = DaprComponentCategory.PubSub,
        ["binding"] = DaprComponentCategory.Binding,
        ["configuration"] = DaprComponentCategory.Configuration,
        ["lock"] = DaprComponentCategory.Lock,
        ["secretstore"] = DaprComponentCategory.SecretStore,
        ["middleware"] = DaprComponentCategory.Middleware,
    };

    private IQueryable<DaprComponentDetail> FilteredComponents
    {
        get
        {
            IEnumerable<DaprComponentDetail> filtered = _components;

            if (!string.IsNullOrEmpty(_categoryFilter)
                && Enum.TryParse<DaprComponentCategory>(_categoryFilter, out DaprComponentCategory cat))
            {
                filtered = filtered.Where(c => c.Category == cat);
            }

            if (!string.IsNullOrEmpty(_searchFilter))
            {
                string search = _searchFilter;
                filtered = filtered.Where(c =>
                    c.ComponentName.Contains(search, StringComparison.OrdinalIgnoreCase)
                    || c.ComponentType.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            return filtered
                .OrderBy(c => (int)c.Category)
                .ThenBy(c => c.ComponentName)
                .AsQueryable();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // AC10: apply deep link filter
        if (!string.IsNullOrEmpty(Type) && _typeMapping.TryGetValue(Type, out DaprComponentCategory category))
        {
            _categoryFilter = category.ToString();
        }

        await LoadDataAsync();
        _ = PollAsync(); // fire-and-forget
    }

    private async Task PollAsync()
    {
        using PeriodicTimer timer = new(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                await InvokeAsync(async () =>
                {
                    try { await LoadDataAsync(); StateHasChanged(); }
                    catch (ObjectDisposedException) { }
                    catch (Exception) { _apiUnavailable = _cachedSidecar is null; _isStale = _cachedSidecar is not null; }
                });
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            DaprSidecarInfo? sidecar = await ApiClient.GetSidecarInfoAsync(_cts.Token);
            IReadOnlyList<DaprComponentDetail> components = await ApiClient.GetComponentsAsync(_cts.Token);

            _sidecar = sidecar;
            _components = components;
            _apiUnavailable = false;
            _isStale = false;
            _lastRefreshUtc = DateTimeOffset.UtcNow;

            if (sidecar is not null)
            {
                _cachedSidecar = sidecar;
            }
        }
        catch (OperationCanceledException)
        {
            // Disposal or navigation cancellation — do not treat as API failure
        }
        catch (Exception)
        {
            _isStale = _cachedSidecar is not null;
            _apiUnavailable = _cachedSidecar is null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnManualRefresh()
    {
        await LoadDataAsync();
    }

    private void OnFilterChanged()
    {
        StateHasChanged();
    }

    private void ClearSearchFilter()
    {
        _searchFilter = string.Empty;
        OnFilterChanged();
    }

    private void OnCategoryFilterChanged(string value)
    {
        _categoryFilter = value;
        StateHasChanged();
    }

    private void OnRowClick(FluentDataGridRow<DaprComponentDetail> row)
    {
        if (row.Item is null)
        {
            return;
        }

        _selectedComponent = _selectedComponent?.ComponentName == row.Item.ComponentName ? null : row.Item;
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }

    private static string GetHealthSeverity(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => "success",
        HealthStatus.Degraded => "warning",
        HealthStatus.Unhealthy => "error",
        _ => "neutral",
    };

    // Severity for the canonical-inventory components count. Surfaces inventory-level health
    // rather than the prior hardcoded "success" — any Unhealthy row tints the card.
    private string GetComponentsCountSeverity()
    {
        if (_components.Any(c => c.Status == HealthStatus.Unhealthy))
        {
            return "error";
        }

        if (_components.Any(c => c.Status == HealthStatus.Degraded))
        {
            return "warning";
        }

        // Empty canonical inventory or all-Healthy.
        return _components.Count == 0 ? "warning" : "success";
    }

    private string GetComponentsCountSubtitle()
    {
        int localOnly = _components.Count(c => c.Source == DaprComponentSource.LocalAdminMetadataFallback);
        int probed = _components.Count(c => c.Source == DaprComponentSource.LocalAdminProbe);
        int remote = _components.Count(c => c.Source == DaprComponentSource.RemoteEventStoreMetadata);
        return $"{remote} remote / {probed} probed / {localOnly} local";
    }

    private string GetRemoteMetadataTitle(DaprSidecarInfo sidecar)
    {
        switch (sidecar.RemoteMetadataStatus)
        {
            case RemoteMetadataStatus.Available:
                return $"Remote eventstore sidecar reachable at {sidecar.RemoteEndpoint}";
            case RemoteMetadataStatus.Unreachable:
                return $"Remote eventstore sidecar unreachable at {sidecar.RemoteEndpoint}";
            case RemoteMetadataStatus.InvalidPayload:
                return $"Remote eventstore sidecar at {sidecar.RemoteEndpoint} returned an invalid payload";
            case RemoteMetadataStatus.NotConfigured:
                return "Remote eventstore sidecar endpoint not configured (AdminServer:EventStoreDaprHttpEndpoint)";
            default:
                Logger.LogWarning("Unrecognised RemoteMetadataStatus '{Status}' in DaprComponents tooltip.", sidecar.RemoteMetadataStatus);
                return "Number of active subscriptions";
        }
    }

    private static string FormatSource(DaprComponentSource source) => source switch
    {
        DaprComponentSource.RemoteEventStoreMetadata => "Remote (eventstore)",
        DaprComponentSource.LocalAdminProbe => "Local probe",
        DaprComponentSource.LocalAdminMetadataFallback => "Local fallback",
        DaprComponentSource.Unavailable => "unavailable",
        // New enum values must be added explicitly. Until the UI map is updated, render the
        // raw enum name so operators can flag the missing translation rather than silently
        // bucketing it under "unavailable".
        _ => $"unknown ({source})",
    };

    private static string GetSourceTitle(DaprComponentSource source) => source switch
    {
        DaprComponentSource.RemoteEventStoreMetadata => "Reported by the remote EventStore sidecar metadata (canonical).",
        DaprComponentSource.LocalAdminProbe => "Confirmed by an Admin.Server local dependency probe.",
        DaprComponentSource.LocalAdminMetadataFallback => "Sourced from local Admin sidecar metadata as a degraded fallback only.",
        DaprComponentSource.Unavailable => "Source attribution unavailable for this fact.",
        _ => $"Unrecognized DaprComponentSource value '{source}' — UI translation missing.",
    };

    private static string FormatTimeAgo(DateTimeOffset timestamp)
    {
        if (timestamp == default)
        {
            return "Never";
        }

        TimeSpan elapsed = DateTimeOffset.UtcNow - timestamp;
        if (elapsed < TimeSpan.Zero || elapsed.TotalSeconds < 60)
        {
            return "just now";
        }

        if (elapsed.TotalMinutes < 60)
        {
            int minutes = (int)elapsed.TotalMinutes;
            return $"{minutes} min ago";
        }

        if (elapsed.TotalHours < 24)
        {
            int hours = (int)elapsed.TotalHours;
            return $"{hours} {(hours == 1 ? "hour" : "hours")} ago";
        }

        return timestamp.ToString("yyyy-MM-dd");
    }
}
