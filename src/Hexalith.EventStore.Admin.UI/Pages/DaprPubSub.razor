@page "/dapr/pubsub"

@using Hexalith.EventStore.Admin.Abstractions.Models.Dapr
@using Hexalith.EventStore.Admin.Abstractions.Models.Health
@using Hexalith.EventStore.Admin.UI.Components.Shared
@using Hexalith.EventStore.Admin.UI.Services

@implements IAsyncDisposable

@inject AdminPubSubApiClient PubSubClient
@inject AdminDeadLetterApiClient DeadLetterClient
@inject AdminStreamApiClient StreamClient
@inject NavigationManager NavigationManager
@inject ILogger<DaprPubSub> Logger

<PageTitle>DAPR Pub/Sub Metrics - Hexalith EventStore</PageTitle>

@* Header with back-link and refresh *@
<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
    <FluentLink Href="/dapr" Appearance="LinkAppearance.Default" aria-label="Back to DAPR Infrastructure">
        &larr; DAPR Infrastructure
    </FluentLink>
</div>

<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
    <h1 style="margin: 0;">DAPR Pub/Sub Delivery Metrics</h1>
    <FluentButton Appearance="ButtonAppearance.Outline" Size="ButtonSize.Small"
                  OnClick="OnManualRefresh"
                  aria-label="Refresh pub/sub metrics">
        Refresh
    </FluentButton>
</div>

@* Error state: API unavailable *@
<IssueBanner Visible="@(_error is not null && _overview is null)"
             Title="Unable to load pub/sub information"
             Description="@(_error ?? "The admin backend service may be unavailable.")"
             ActionLabel="Retry"
             OnAction="LoadDataAsync" />

@* Summary stat cards (AC1, AC2, AC4) *@
<FluentGrid Spacing="3" style="margin-bottom: 16px;">
    @if (_isLoading)
    {
        <FluentGridItem xs="6" sm="6" md="3"><SkeletonCard /></FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3"><SkeletonCard /></FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3"><SkeletonCard /></FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3"><SkeletonCard /></FluentGridItem>
    }
    else if (_overview is not null)
    {
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Pub/Sub Components"
                      Value="@_overview.PubSubComponents.Count.ToString()"
                      Severity="@(_overview.PubSubComponents.Count > 0 ? "success" : "neutral")"
                      Title="Number of registered pub/sub components" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Active Subscriptions"
                      Value="@(_overview.RemoteMetadataStatus == RemoteMetadataStatus.Available ? _overview.Subscriptions.Count.ToString() : "N/A")"
                      Severity="@(_overview.RemoteMetadataStatus == RemoteMetadataStatus.Available && _overview.Subscriptions.Count > 0 ? "success" : "neutral")"
                      Title="Number of active DAPR subscriptions" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Unique Topics"
                      Value="@(_overview.RemoteMetadataStatus == RemoteMetadataStatus.Available ? _overview.Subscriptions.Select(s => s.Topic).Distinct().Count().ToString() : "N/A")"
                      Severity="neutral"
                      Title="Number of distinct subscription topics" />
        </FluentGridItem>
        <FluentGridItem xs="6" sm="6" md="3">
            <StatCard Label="Dead Letters"
                      Value="@(_deadLetterCount.HasValue ? _deadLetterCount.Value.ToString() : "N/A")"
                      Severity="@GetDeadLetterSeverity()"
                      Title="Total dead-letter entries" />
        </FluentGridItem>
    }
</FluentGrid>

@* Empty states: No pub/sub components — distinguishes the three remote-metadata states *@
@if (!_isLoading && _overview is not null && _overview.PubSubComponents.Count == 0 && _error is null)
{
    @switch (_overview.RemoteMetadataStatus)
    {
        case RemoteMetadataStatus.NotConfigured:
            <EmptyState Title="Pub/sub components unavailable"
                        Description="Remote EventStore sidecar metadata is disabled. Set 'AdminServer:EventStoreDaprHttpEndpoint' in appsettings (under Aspire, this is wired automatically)." />
            break;
        case RemoteMetadataStatus.Unreachable:
            <EmptyState Title="EventStore sidecar unreachable"
                        Description="@($"Cannot list pub/sub components — the query to {_overview.RemoteEndpoint}/v1.0/metadata failed. Verify the EventStore DAPR sidecar is running on that port. Check Admin server logs for the exception details.")" />
            break;
        case RemoteMetadataStatus.Available:
            <EmptyState Title="No pub/sub components found"
                        Description="The EventStore sidecar is reachable but reports no pub/sub components. Check that 'pubsub' is registered as a DAPR component and referenced by the EventStore sidecar in HexalithEventStoreExtensions.cs." />
            break;
    }
}

@* Pub/sub component cards (AC1) *@
@if (!_isLoading && _overview is not null && _overview.PubSubComponents.Count > 0)
{
    <h2 style="margin: 0 0 12px;">Pub/Sub Components</h2>
    <FluentGrid Spacing="3" style="margin-bottom: 24px;">
        @foreach (DaprComponentDetail component in _overview.PubSubComponents)
        {
            <FluentGridItem xs="12" sm="6" md="@(_overview.PubSubComponents.Count == 1 ? 12 : 6)">
                <FluentCard class="@GetComponentCardClass(component.ComponentName)" style="padding: 16px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <strong>@component.ComponentName</strong>
                        <StatusBadge Severity="@GetHealthSeverity(component.Status)"
                                     Status="@component.Status.ToString()"
                                     AriaLabelPrefix="Component status" />
                    </div>
                    <div style="margin-bottom: 8px;">
                        <span style="color: var(--colorNeutralForeground3);">Type:</span> @component.ComponentType
                    </div>
                    <div style="margin-bottom: 8px;">
                        <span style="color: var(--colorNeutralForeground3);">Version:</span> @(string.IsNullOrEmpty(component.Version) ? "N/A" : component.Version)
                    </div>
                    @if (component.Capabilities.Count > 0)
                    {
                        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px;">
                            @foreach (string cap in component.Capabilities)
                            {
                                <FluentBadge Appearance="BadgeAppearance.Filled" Content="@cap" />
                            }
                        </div>
                    }
                </FluentCard>
            </FluentGridItem>
        }
    </FluentGrid>
}

@* Subscription grid (AC2) *@
@if (!_isLoading && _overview is not null)
{
    <h2 style="margin: 0 0 12px;">Subscriptions</h2>

    @* Remote metadata status banner (AC8) *@
    @switch (_overview.RemoteMetadataStatus)
    {
        case RemoteMetadataStatus.NotConfigured:
            <IssueBanner Visible="true"
                         Title="Remote metadata disabled"
                         Description="Subscription data is only available when 'AdminServer:EventStoreDaprHttpEndpoint' is configured. Under Aspire this is wired automatically." />
            break;
        case RemoteMetadataStatus.Unreachable:
            <IssueBanner Visible="true"
                         Title="EventStore sidecar unreachable"
                         Description="@($"Attempted to query {_overview.RemoteEndpoint}/v1.0/metadata but the call failed. Verify the EventStore DAPR sidecar is running. Check Admin server logs for details.")" />
            break;
        case RemoteMetadataStatus.Available:
            break;
    }

    @if (_overview.Subscriptions.Count > 0)
    {
        <div style="margin-bottom: 12px;">
            <FluentTextInput @bind-Value="_searchFilter"
                          @bind-Value:after="OnFilterChanged"
                          Placeholder="Filter by topic or route..."
                          style="min-width: 200px;"
                          aria-label="Filter subscriptions by topic or route"
                          TextInputType="TextInputType.Text">
                <StartTemplate>
                    <FluentIcon Value="@(new Icons.Regular.Size16.Search())" />
                </StartTemplate>
                <EndTemplate>
                    <FluentButton Appearance="ButtonAppearance.Transparent"
                                  Disabled="@(string.IsNullOrEmpty(_searchFilter))"
                                  OnClick="ClearSearchFilter"
                                  aria-label="Clear search"
                                  Title="Clear search">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Dismiss())" />
                    </FluentButton>
                </EndTemplate>
            </FluentTextInput>
        </div>

        <FluentDataGrid Items="@FilteredSubscriptions" TGridItem="DaprSubscriptionInfo"
                        Style="width: 100%; margin-bottom: 24px;"
                        aria-label="DAPR pub/sub subscriptions">
            <PropertyColumn Property="@(s => s.Topic)" Title="Topic" Sortable="true"
                            IsDefaultSortColumn="true" InitialSortDirection="SortDirection.Ascending" />
            <PropertyColumn Property="@(s => s.Route)" Title="Route" Sortable="true" />
            <PropertyColumn Property="@(s => s.PubSubName)" Title="PubSub Component" Sortable="true" />
            <PropertyColumn Property="@(s => s.SubscriptionType)" Title="Type" Sortable="true" />
            <TemplateColumn Title="Dead Letter Topic" Sortable="false">
                @(context.DeadLetterTopic ?? "None")
            </TemplateColumn>
        </FluentDataGrid>
    }
    else if (_overview.RemoteMetadataStatus == RemoteMetadataStatus.Available)
    {
        <div style="color: var(--colorNeutralForeground3); margin-bottom: 24px; font-style: italic;">
            No active subscriptions registered on the EventStore server sidecar.
        </div>
    }
}

@* Topic topology and publication pipeline reference cards (AC3) *@
@if (!_isLoading && _overview is not null && _overview.PubSubComponents.Count > 0)
{
    <h2 style="margin: 0 0 12px;">Reference</h2>
    <FluentAccordion style="margin-bottom: 24px;">
        <FluentAccordionItem Heading="Topic Topology &amp; Publication Pipeline">
            <FluentCard style="padding: 16px; margin-bottom: 16px;">
                <h3 style="margin: 0 0 12px;">Topic Topology</h3>
                <dl style="display: grid; grid-template-columns: auto 1fr; gap: 8px 16px; margin: 0;">
                    <dt style="font-weight: 600;">Event topic pattern</dt>
                    <dd style="margin: 0; font-family: monospace;">{tenant}.{domain}.events</dd>
                    <dt style="font-weight: 600;">Dead-letter topic pattern</dt>
                    <dd style="margin: 0; font-family: monospace;">deadletter.{tenant}.{domain}.events</dd>
                    <dt style="font-weight: 600;">Delivery semantics</dt>
                    <dd style="margin: 0;">At-least-once &middot; CloudEvents 1.0 &middot; Subscribers must be idempotent</dd>
                    <dt style="font-weight: 600;">Pub/sub component</dt>
                    <dd style="margin: 0;">@(_overview.PubSubComponents.FirstOrDefault()?.ComponentName ?? "N/A")</dd>
                </dl>
            </FluentCard>

            <FluentCard style="padding: 16px;">
                <h3 style="margin: 0 0 12px;">Publication Pipeline</h3>
                <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 12px;">
                    <FluentBadge Appearance="BadgeAppearance.Filled" style="padding: 6px 12px;" Content="EventsStored" />
                    <span style="color: var(--colorNeutralForeground3);">&rsaquo;</span>
                    <FluentBadge Appearance="BadgeAppearance.Filled" style="padding: 6px 12px;" Content="EventsPublished" />
                    <span style="color: var(--colorNeutralForeground3);">&rsaquo;</span>
                    <FluentBadge style="padding: 6px 12px; background: var(--hexalith-status-success); color: white;" Content="Completed" />
                </div>
                <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
                    <span style="color: var(--colorNeutralForeground3); margin-left: 24px;">&darr; on failure</span>
                    <FluentBadge style="padding: 6px 12px; background: var(--hexalith-status-error); color: white;" Content="PublishFailed" />
                    <span style="color: var(--colorNeutralForeground3);">&rsaquo;</span>
                    <span>Dead-letter routing &mdash; investigate via Dead Letter Manager</span>
                </div>
            </FluentCard>
        </FluentAccordionItem>
    </FluentAccordion>
}

@* Observability deep-link cards (AC5) *@
@if (!_isLoading && _overview is not null)
{
    <h2 style="margin: 0 0 12px;">Observability</h2>
    <FluentGrid Spacing="3" style="margin-bottom: 24px;">
        <FluentGridItem xs="12" sm="4">
            <FluentCard style="padding: 16px; text-align: center;">
                <strong>Traces</strong>
                <div style="margin-top: 8px;">
                    @if (!string.IsNullOrEmpty(_observabilityLinks?.TraceUrl))
                    {
                        <FluentAnchorButton Href="@_observabilityLinks.TraceUrl" Target="LinkTarget.Blank"
                                            Appearance="ButtonAppearance.Primary"
                                            aria-label="Open trace dashboard">
                            Open Trace Dashboard
                        </FluentAnchorButton>
                    }
                    else
                    {
                        <span style="color: var(--colorNeutralForeground3); font-size: 0.85em;">Configure observability URL to enable</span>
                    }
                </div>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="4">
            <FluentCard style="padding: 16px; text-align: center;">
                <strong>Metrics</strong>
                <div style="margin-top: 8px;">
                    @if (!string.IsNullOrEmpty(_observabilityLinks?.MetricsUrl))
                    {
                        <FluentAnchorButton Href="@_observabilityLinks.MetricsUrl" Target="LinkTarget.Blank"
                                            Appearance="ButtonAppearance.Primary"
                                            aria-label="Open metrics dashboard">
                            Open Metrics Dashboard
                        </FluentAnchorButton>
                    }
                    else
                    {
                        <span style="color: var(--colorNeutralForeground3); font-size: 0.85em;">Configure observability URL to enable</span>
                    }
                </div>
            </FluentCard>
        </FluentGridItem>
        <FluentGridItem xs="12" sm="4">
            <FluentCard style="padding: 16px; text-align: center;">
                <strong>Logs</strong>
                <div style="margin-top: 8px;">
                    @if (!string.IsNullOrEmpty(_observabilityLinks?.LogsUrl))
                    {
                        <FluentAnchorButton Href="@_observabilityLinks.LogsUrl" Target="LinkTarget.Blank"
                                            Appearance="ButtonAppearance.Primary"
                                            aria-label="Open logs dashboard">
                            Open Logs Dashboard
                        </FluentAnchorButton>
                    }
                    else
                    {
                        <span style="color: var(--colorNeutralForeground3); font-size: 0.85em;">Configure observability URL to enable</span>
                    }
                </div>
            </FluentCard>
        </FluentGridItem>
    </FluentGrid>
}

@* Dead-letter management card (AC4) *@
@if (!_isLoading && _overview is not null)
{
    <FluentCard style="padding: 16px; margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <strong>Dead Letter Management</strong>
                <div style="margin-top: 4px;">
                    Dead letters:
                    <span style="font-weight: 600; color: @GetDeadLetterColor();">
                        @(_deadLetterCount.HasValue ? _deadLetterCount.Value.ToString() : "N/A")
                    </span>
                </div>
            </div>
            <FluentButton Appearance="ButtonAppearance.Primary"
                          OnClick="@(() => NavigationManager.NavigateTo("/health/dead-letters"))"
                          aria-label="Navigate to Dead Letter Manager">
                Manage Dead Letters
            </FluentButton>
        </div>
    </FluentCard>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private DaprPubSubOverview? _overview;
    private int? _deadLetterCount;
    private ObservabilityLinks? _observabilityLinks;
    private bool _isLoading = true;
    private string? _error;
    private string? _searchFilter;
    private IQueryable<DaprSubscriptionInfo>? _filteredSubscriptionsCache;

    /// <summary>
    /// Gets or sets the pub/sub component name for deep linking (AC9).
    /// </summary>
    [SupplyParameterFromQuery(Name = "component")]
    public string? Component { get; set; }

    private IQueryable<DaprSubscriptionInfo> FilteredSubscriptions
        => _filteredSubscriptionsCache ??= BuildFilteredSubscriptions();

    private IQueryable<DaprSubscriptionInfo> BuildFilteredSubscriptions()
    {
        IEnumerable<DaprSubscriptionInfo> filtered = _overview?.Subscriptions ?? [];

        if (!string.IsNullOrEmpty(_searchFilter))
        {
            string search = _searchFilter;
            filtered = filtered.Where(s =>
                s.Topic.Contains(search, StringComparison.OrdinalIgnoreCase)
                || s.Route.Contains(search, StringComparison.OrdinalIgnoreCase));
        }

        return filtered.OrderBy(s => s.Topic).AsQueryable();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadObservabilityLinksAsync();
        await LoadDataAsync();
        _ = PollAsync(); // fire-and-forget
    }

    private async Task LoadObservabilityLinksAsync()
    {
        try
        {
            SystemHealthReport? health = await StreamClient.GetSystemHealthAsync(_cts.Token);
            _observabilityLinks = health?.ObservabilityLinks;
        }
        catch (OperationCanceledException) { throw; }
        catch (Exception ex) { Logger.LogWarning(ex, "Failed to fetch observability links"); }
    }

    private async Task PollAsync()
    {
        using PeriodicTimer timer = new(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                await InvokeAsync(async () =>
                {
                    try { await LoadDataAsync(); StateHasChanged(); }
                    catch (ObjectDisposedException) { }
                    catch (Exception ex) { Logger.LogWarning(ex, "Poll cycle failed"); }
                });
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadDataAsync()
    {
        DaprPubSubOverview? overviewResult = null;
        int? deadLetterResult = null;
        string? errorMessage = null;

        async Task FetchOverviewAsync()
        {
            try { overviewResult = await PubSubClient.GetPubSubOverviewAsync(_cts.Token); }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex) { Logger.LogWarning(ex, "Failed to fetch pub/sub overview"); errorMessage = ex.Message; }
        }

        async Task FetchDeadLetterCountAsync()
        {
            try { deadLetterResult = await DeadLetterClient.GetDeadLetterCountAsync(_cts.Token); }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex) { Logger.LogWarning(ex, "Failed to fetch dead-letter count"); }
        }

        await Task.WhenAll(FetchOverviewAsync(), FetchDeadLetterCountAsync());

        _overview = overviewResult;
        _deadLetterCount = deadLetterResult;
        _filteredSubscriptionsCache = null;
        _error = overviewResult is null ? (errorMessage ?? "Failed to load pub/sub overview.") : null;
        _isLoading = false;
    }

    private async Task OnManualRefresh()
    {
        await LoadDataAsync();
    }

    private void OnFilterChanged()
    {
        _filteredSubscriptionsCache = null;
        StateHasChanged();
    }

    private void ClearSearchFilter()
    {
        _searchFilter = string.Empty;
        OnFilterChanged();
    }

    private string GetComponentCardClass(string componentName)
    {
        if (!string.IsNullOrEmpty(Component)
            && string.Equals(componentName, Component, StringComparison.OrdinalIgnoreCase))
        {
            return "highlighted-card";
        }

        return string.Empty;
    }

    private string GetDeadLetterSeverity()
    {
        if (!_deadLetterCount.HasValue)
        {
            return "neutral";
        }

        return _deadLetterCount.Value == 0 ? "success" : "warning";
    }

    private string GetDeadLetterColor()
    {
        if (!_deadLetterCount.HasValue)
        {
            return "var(--colorNeutralForeground1)";
        }

        return _deadLetterCount.Value == 0
            ? "var(--hexalith-status-success)"
            : "var(--hexalith-status-warning)";
    }

    private static string GetHealthSeverity(HealthStatus status) => status switch
    {
        HealthStatus.Healthy => "success",
        HealthStatus.Degraded => "warning",
        HealthStatus.Unhealthy => "error",
        _ => "neutral",
    };

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}

<style>
    .highlighted-card {
        border: 2px solid var(--colorBrandBackground);
        box-shadow: 0 0 8px var(--colorBrandBackground);
    }
</style>
