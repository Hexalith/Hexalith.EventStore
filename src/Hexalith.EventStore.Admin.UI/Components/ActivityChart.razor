@namespace Hexalith.EventStore.Admin.UI.Components

@using Hexalith.EventStore.Admin.UI.Models

@inject NavigationManager NavigationManager

<div class="activity-chart">
    <h3 class="activity-chart-title">Stream Activity (24h)</h3>

    @if (IsLoading)
    {
        <div class="activity-chart-skeleton" aria-hidden="true">
            @for (int i = 0; i < 24; i++)
            {
                <div class="activity-chart-skeleton-bar" style="height: @(_skeletonHeights[i])%"></div>
            }
        </div>
    }
    else if (Buckets is null || Buckets.Count == 0 || Buckets.All(b => b.StreamCount == 0))
    {
        <EmptyState Title="No stream activity in the last 24 hours" Description="" />
    }
    else
    {
        int maxCount = Buckets.Max(b => b.StreamCount);
        int totalActive = Buckets.Sum(b => b.StreamCount);
        IReadOnlyList<ActivityBucket> displayBuckets = GetDisplayBuckets();
        <div class="activity-chart-bars" role="img" aria-label="Bar chart showing stream activity over the last 24 hours">
            @foreach (ActivityBucket bucket in displayBuckets)
            {
                double heightPct = maxCount > 0 ? (double)bucket.StreamCount / maxCount * 100 : 0;
                string timeRange = $"{bucket.Start:HH:mm}-{bucket.End:HH:mm}";
                string ariaLabel = $"{timeRange}: {bucket.StreamCount} active streams";
                <button class="activity-chart-bar-wrapper"
                        title="@($"{timeRange}: {bucket.StreamCount} streams")"
                        aria-label="@ariaLabel"
                        @onclick="() => OnBarClick(bucket)">
                    <div class="activity-chart-bar" style="height: @($"{heightPct:F0}%")"></div>
                </button>
            }
        </div>

        @* Minimum breakpoint summary text (shown via CSS when bars are hidden) *@
        <div class="activity-chart-summary" aria-live="polite">
            @totalActive streams active in last 24 hours
        </div>

        @* Hidden data table for screen reader accessibility *@
        <table class="sr-only" aria-label="Stream activity data for the last 24 hours">
            <thead>
                <tr>
                    <th scope="col">Time Range</th>
                    <th scope="col">Active Streams</th>
                </tr>
            </thead>
            <tbody>
                @foreach (ActivityBucket bucket in Buckets)
                {
                    <tr>
                        <td>@bucket.Start.ToString("HH:mm") - @bucket.End.ToString("HH:mm")</td>
                        <td>@bucket.StreamCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    // Deterministic skeleton heights to avoid re-render flicker
    private static readonly int[] _skeletonHeights =
        [45, 72, 38, 61, 83, 29, 55, 77, 42, 68, 35, 58, 80, 47, 63, 31, 74, 50, 66, 39, 71, 54, 82, 44];

    [Parameter]
    public IReadOnlyList<ActivityBucket>? Buckets { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    private IReadOnlyList<ActivityBucket> GetDisplayBuckets()
    {
        if (Buckets is null || Buckets.Count == 0)
        {
            return [];
        }

        // At Compact breakpoint (<=1279px), merge into 12 bars with 2h buckets
        // This is handled server-side since CSS can't merge data; we provide both
        // and let CSS show/hide the appropriate container.
        // For simplicity, always render 24 bars — CSS handles visibility.
        return Buckets;
    }

    private void OnBarClick(ActivityBucket bucket)
    {
        string start = bucket.Start.ToString("o");
        string end = bucket.End.ToString("o");
        NavigationManager.NavigateTo($"/streams?start={Uri.EscapeDataString(start)}&end={Uri.EscapeDataString(end)}");
    }
}
