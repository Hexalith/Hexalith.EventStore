@using Hexalith.EventStore.Admin.Abstractions.Models.Common
@using Hexalith.EventStore.Admin.UI.Services
@inject TopologyCacheService TopologyCache
@inject DashboardRefreshService RefreshService
@inject NavigationManager Navigation
@implements IDisposable

<nav aria-label="Main navigation">
    <FluentNavMenu Width="@Width" Title="Admin Navigation" @bind-Expanded="_expanded">
        <FluentNavLink Href="/" Icon="@(new Icons.Regular.Size20.Home())" IconColor="Color.Accent">Home</FluentNavLink>
        <FluentNavLink Href="/commands" Icon="@(new Icons.Regular.Size20.List())">Commands</FluentNavLink>
        <FluentNavLink Href="/events" Icon="@(new Icons.Regular.Size20.Timeline())">Events</FluentNavLink>
        <FluentNavLink Href="/streams" Icon="@(new Icons.Regular.Size20.DataLine())">Streams</FluentNavLink>
        <FluentNavLink Href="/health" Icon="@(new Icons.Regular.Size20.HeartPulse())">Health</FluentNavLink>
        <FluentNavLink Href="/projections" Icon="@(new Icons.Regular.Size20.LayerDiagonal())">Projections</FluentNavLink>
        <FluentNavLink Href="/services" Icon="@(new Icons.Regular.Size20.Server())">Services</FluentNavLink>
        <FluentNavLink Href="/tenants" Icon="@(new Icons.Regular.Size20.People())">Tenants</FluentNavLink>
        @if (UserRole >= AdminRole.Admin)
        {
            <FluentNavLink Href="/settings" Icon="@(new Icons.Regular.Size20.Settings())">Settings</FluentNavLink>
        }
        <FluentNavGroup Title="Topology" Icon="@(new Icons.Regular.Size20.BranchFork())" Expanded="false">
            @if (!TopologyCache.IsLoaded)
            {
                <FluentTreeView>
                    <FluentTreeItem Text="Loading..." Disabled="true" />
                </FluentTreeView>
            }
            else if (TopologyCache.Tenants.Count == 0)
            {
                <FluentTreeView>
                    <FluentTreeItem Text="No tenants" Disabled="true" />
                </FluentTreeView>
            }
            else
            {
                <FluentTreeView>
                    @foreach (var tenant in TopologyCache.Tenants)
                    {
                        <FluentTreeItem Text="@tenant.TenantId" Expanded="false">
                            @foreach (string domain in TopologyCache.Domains)
                            {
                                <FluentTreeItem Text="@domain"
                                                @onclick="@(() => NavigateToStreams(tenant.TenantId, domain))" />
                            }
                        </FluentTreeItem>
                    }
                </FluentTreeView>
            }
        </FluentNavGroup>
    </FluentNavMenu>
</nav>

@code {
    [Parameter]
    public int Width { get; set; } = 220;

    [Parameter]
    public AdminRole UserRole { get; set; } = AdminRole.ReadOnly;

    private bool _expanded = true;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        RefreshService.OnDataChanged += OnDataChanged;
        await TopologyCache.EnsureLoadedAsync().ConfigureAwait(false);
    }

    private async void OnDataChanged(DashboardData data)
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            await TopologyCache.RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            // Component disposed during async callback
        }
        catch (Exception)
        {
            // Topology refresh failed — keep stale cache, don't crash
        }
    }

    private void NavigateToStreams(string tenantId, string domain)
    {
        Navigation.NavigateTo($"/streams?tenant={Uri.EscapeDataString(tenantId)}&domain={Uri.EscapeDataString(domain)}");
    }

    public void Dispose()
    {
        _disposed = true;
        RefreshService.OnDataChanged -= OnDataChanged;
    }
}
