@using Hexalith.EventStore.Admin.Abstractions.Models.Common
@using Hexalith.EventStore.Admin.UI.Services
@using Hexalith.EventStore.Admin.UI.Components
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AdminUserContext UserContext
@inject EventStoreSignalRClient SignalRClient
@inject DashboardRefreshService RefreshService
@inject ThemeState ThemeState
@inject ViewportService ViewportService
@inject DevelopmentAdminRoleState RoleState
@implements IAsyncDisposable

<a href="#main-content" class="skip-to-main">Skip to main content</a>

<FluentLayout>
    <FluentLayoutItem Area="@LayoutArea.Header">
        <FluentLayoutHamburger />
        <div style="display: flex; align-items: center; width: 100%; justify-content: space-between;">
            <span style="font-weight: 600;">Hexalith EventStore Admin</span>
            <div style="display: flex; align-items: center; gap: 12px;">
                <HeaderStatusIndicator ConnectionStatus="_connectionStatus" HealthSummary="@_healthSummary" />
                @if (RoleState.IsRoleSwitcherAvailable)
                {
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <FluentSelect TOption="string" TValue="string"
                                      Value="@_selectedRoleValue"
                                      ValueChanged="OnSelectedRoleChangedAsync"
                                      aria-label="Development role"
                                      style="min-width: 120px;">
                            <FluentOption Value="@nameof(AdminRole.ReadOnly)">ReadOnly</FluentOption>
                            <FluentOption Value="@nameof(AdminRole.Operator)">Operator</FluentOption>
                            <FluentOption Value="@nameof(AdminRole.Admin)">Admin</FluentOption>
                        </FluentSelect>
                        <span style="font-size: 12px; color: var(--colorNeutralForeground3);">Role: @_selectedRoleValue</span>
                    </div>
                    <span class="visually-hidden" aria-live="polite">@_roleAnnouncement</span>
                }
                <ThemeToggle />
            </div>
        </div>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Navigation" Width="@(_sidebarCollapsed ? "140px" : "220px")" Class="@($"admin-sidebar{(_sidebarCollapsed ? " collapsed" : string.Empty)}")">
        <NavMenu Width="@(_sidebarCollapsed ? "140px" : "220px")" UserRole="_userRole" />
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Content">
        <div class="narrow-screen-warning" role="alert">
            Dashboard optimized for wider screens.
        </div>
        <Breadcrumb />
        <main id="main-content" class="admin-main" role="main">
            @Body
        </main>
    </FluentLayoutItem>
</FluentLayout>

<FluentProviders />

<CommandPalette @ref="_commandPalette" />

@code {
    private bool _sidebarCollapsed;
    private AdminRole _userRole = AdminRole.ReadOnly;
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private CommandPalette? _commandPalette;
    private string? _shortcutRegistrationId;
    private HeaderStatusIndicator.ConnectionStatusType _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Unknown;
    private string _healthSummary = "\u2014";
    private bool _pollingFailed;
    private bool _pollingSucceeded;
    private string _selectedRoleValue = nameof(AdminRole.Admin);
    private string _roleAnnouncement = "Development role Admin selected.";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wire theme changes
            ThemeState.Changed += OnThemeChanged;

            // Wire connection status from SignalR + polling
            RefreshService.OnDataChanged += OnPollingSuccess;
            RefreshService.OnError += OnPollingFailure;
            RoleState.RoleChanged += OnDevelopmentRoleChanged;
            RefreshService.Start();
            _ = RefreshService.TriggerImmediateRefreshAsync();
            UpdateConnectionStatus();

            _userRole = await UserContext.GetRoleAsync();
            _selectedRoleValue = RoleState.SelectedRole.ToString();

            try
            {
                await LoadSidebarStateForCurrentTierAsync();

                // Subscribe to viewport changes so the sidebar auto-collapses when
                // the window narrows below 1280px and restores the user's saved
                // state for the new tier when it widens back. Without this, the
                // sidebar stays at whatever state it had on first render and
                // fights the CSS media queries.
                await ViewportService.InitializeAsync();
                ViewportService.OnViewportChanged += OnViewportChanged;

                _dotNetRef = DotNetObjectReference.Create(this);
                _shortcutRegistrationId = await JSRuntime.InvokeAsync<string>("hexalithAdmin.registerShortcuts", _dotNetRef);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected during render — safe to ignore
            }

            StateHasChanged();
        }
    }

    private async Task LoadSidebarStateForCurrentTierAsync()
    {
        string storageKey = await GetSidebarStorageKeyAsync();
        string? savedState = await JSRuntime.InvokeAsync<string?>("hexalithAdmin.getLocalStorage", storageKey);
        if (bool.TryParse(savedState, out bool collapsed))
        {
            _sidebarCollapsed = collapsed;
        }
        else
        {
            // Two states only:
            //   _sidebarCollapsed = false → Normal: 220px, icons + labels (≥1280px default)
            //   _sidebarCollapsed = true  → Compact-text: 140px, labels only, no icons (<1280px default)
            // Ctrl+B toggles between the two regardless of viewport (saved per-tier).
            _sidebarCollapsed = IsNarrowTier(storageKey);
        }
    }

    private void OnViewportChanged()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await LoadSidebarStateForCurrentTierAsync();
                StateHasChanged();
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected during resize — safe to ignore
            }
            catch (ObjectDisposedException)
            {
                // Component disposed mid-resize — safe to ignore
            }
        });
    }

    [JSInvokable]
    public async Task OnCommandPaletteShortcut()
    {
        await InvokeAsync(async () =>
        {
            if (_commandPalette is not null)
            {
                await _commandPalette.OpenAsync(force: true);
            }
        });
    }

    [JSInvokable]
    public async Task OnToggleSidebarShortcut()
    {
        await InvokeAsync(async () =>
        {
            try
            {
                _sidebarCollapsed = !_sidebarCollapsed;
                string storageKey = await GetSidebarStorageKeyAsync();
                await JSRuntime.InvokeVoidAsync("hexalithAdmin.setLocalStorage", storageKey, _sidebarCollapsed.ToString().ToLowerInvariant());
                StateHasChanged();
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected mid-shortcut — safe to ignore
            }
        });
    }

    private async Task<string> GetSidebarStorageKeyAsync()
    {
        int viewportWidth = await JSRuntime.InvokeAsync<int>("hexalithAdmin.getViewportWidth");
        string tier = viewportWidth switch
        {
            >= 1920 => "optimal",
            >= 1280 => "standard",
            >= 960 => "compact",
            _ => "minimum",
        };

        return $"hexalith-sidebar-collapsed-{tier}";
    }

    // Narrow viewport tiers default to a collapsed sidebar when no saved state exists.
    // compact and minimum both qualify; optimal/standard do not.
    private static bool IsNarrowTier(string storageKey)
        => storageKey.EndsWith("-compact", StringComparison.Ordinal)
            || storageKey.EndsWith("-minimum", StringComparison.Ordinal);

    private void OnPollingSuccess(DashboardData data)
    {
        _pollingFailed = false;
        _pollingSucceeded = true;
        if (data.Health is not null)
        {
            _healthSummary = data.Health.OverallStatus.ToString();
        }

        _ = InvokeAsync(() =>
        {
            try
            {
                UpdateConnectionStatus();
                StateHasChanged();
            }
            catch (ObjectDisposedException)
            {
                // Component disposed during async callback
            }
        });
    }

    private void OnPollingFailure(Exception ex)
    {
        _pollingFailed = true;
        _pollingSucceeded = false;
        _ = InvokeAsync(() =>
        {
            try
            {
                UpdateConnectionStatus();
                StateHasChanged();
            }
            catch (ObjectDisposedException)
            {
                // Component disposed during async callback
            }
        });
    }

    private void UpdateConnectionStatus()
    {
        bool signalRConnected = SignalRClient?.IsConnected ?? false;
        if (signalRConnected || _pollingSucceeded)
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Connected;
        }
        else if (_pollingFailed)
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Disconnected;
        }
        else
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Unknown;
        }
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private Task OnSelectedRoleChangedAsync(string? value)
    {
        if (Enum.TryParse(value, ignoreCase: false, out AdminRole role))
        {
            RoleState.SetRole(role);
        }

        return Task.CompletedTask;
    }

    private void OnDevelopmentRoleChanged(AdminRole role)
    {
        _ = InvokeAsync(() =>
        {
            _userRole = role;
            _selectedRoleValue = role.ToString();
            _roleAnnouncement = $"Development role {role} selected.";
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        ThemeState.Changed -= OnThemeChanged;
        RefreshService.OnDataChanged -= OnPollingSuccess;
        RefreshService.OnError -= OnPollingFailure;
        RoleState.RoleChanged -= OnDevelopmentRoleChanged;
        ViewportService.OnViewportChanged -= OnViewportChanged;

        try
        {
            if (!string.IsNullOrWhiteSpace(_shortcutRegistrationId))
            {
                await JSRuntime.InvokeVoidAsync("hexalithAdmin.unregisterShortcuts", _shortcutRegistrationId);
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit already disconnected — safe to ignore
        }

        _dotNetRef?.Dispose();
    }
}
