@using Hexalith.EventStore.Admin.Abstractions.Models.Common
@using Hexalith.EventStore.Admin.UI.Services
@using Hexalith.EventStore.Admin.UI.Components
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject AdminUserContext UserContext
@inject EventStoreSignalRClient SignalRClient
@inject DashboardRefreshService RefreshService
@inject ThemeState ThemeState
@implements IAsyncDisposable

<a href="#main-content" class="skip-to-main">Skip to main content</a>

<FluentLayout>
    <FluentLayoutItem Area="@LayoutArea.Header">
        <FluentLayoutHamburger />
        <div style="display: flex; align-items: center; width: 100%; justify-content: space-between;">
            <span style="font-weight: 600;">Hexalith EventStore Admin</span>
            <div style="display: flex; align-items: center; gap: 12px;">
                <HeaderStatusIndicator ConnectionStatus="_connectionStatus" HealthSummary="@_healthSummary" />
                <ThemeToggle />
            </div>
        </div>
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Navigation" Width="@(_sidebarCollapsed ? "48px" : "220px")" Class="admin-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <NavMenu Width="@(_sidebarCollapsed ? "48px" : "220px")" UserRole="_userRole" />
    </FluentLayoutItem>

    <FluentLayoutItem Area="@LayoutArea.Content">
        <div class="narrow-screen-warning" role="alert">
            Dashboard optimized for wider screens.
        </div>
        <Breadcrumb />
        <main id="main-content" class="admin-main" role="main">
            @Body
        </main>
    </FluentLayoutItem>
</FluentLayout>

<CommandPalette @ref="_commandPalette" />

@code {
    private bool _sidebarCollapsed;
    private AdminRole _userRole = AdminRole.ReadOnly;
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private CommandPalette? _commandPalette;
    private string? _shortcutRegistrationId;
    private HeaderStatusIndicator.ConnectionStatusType _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Unknown;
    private string _healthSummary = "\u2014";
    private bool _pollingFailed;
    private bool _pollingSucceeded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wire theme changes
            ThemeState.Changed += OnThemeChanged;

            // Wire connection status from SignalR + polling
            RefreshService.OnDataChanged += OnPollingSuccess;
            RefreshService.OnError += OnPollingFailure;
            RefreshService.Start();
            _ = RefreshService.TriggerImmediateRefreshAsync();
            UpdateConnectionStatus();

            _userRole = await UserContext.GetRoleAsync();

            try
            {
                string storageKey = await GetSidebarStorageKeyAsync();
                string? savedState = await JSRuntime.InvokeAsync<string?>("hexalithAdmin.getLocalStorage", storageKey);
                if (bool.TryParse(savedState, out bool collapsed))
                {
                    _sidebarCollapsed = collapsed;
                }
                else if (storageKey.Contains("compact", StringComparison.Ordinal))
                {
                    _sidebarCollapsed = true;
                }

                _dotNetRef = DotNetObjectReference.Create(this);
                _shortcutRegistrationId = await JSRuntime.InvokeAsync<string>("hexalithAdmin.registerShortcuts", _dotNetRef);
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected during render — safe to ignore
            }

            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnCommandPaletteShortcut()
    {
        if (_commandPalette is not null)
        {
            await _commandPalette.OpenAsync().ConfigureAwait(false);
        }
    }

    [JSInvokable]
    public async Task OnToggleSidebarShortcut()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
        string storageKey = await GetSidebarStorageKeyAsync().ConfigureAwait(false);
        await JSRuntime.InvokeVoidAsync("hexalithAdmin.setLocalStorage", storageKey, _sidebarCollapsed.ToString().ToLowerInvariant()).ConfigureAwait(false);
        StateHasChanged();
    }

    private async Task<string> GetSidebarStorageKeyAsync()
    {
        int viewportWidth = await JSRuntime.InvokeAsync<int>("hexalithAdmin.getViewportWidth").ConfigureAwait(false);
        string tier = viewportWidth switch
        {
            >= 1920 => "optimal",
            >= 1280 => "standard",
            >= 960 => "compact",
            _ => "minimum",
        };

        return $"hexalith-sidebar-collapsed-{tier}";
    }

    private void OnPollingSuccess(DashboardData data)
    {
        _pollingFailed = false;
        _pollingSucceeded = true;
        if (data.Health is not null)
        {
            _healthSummary = data.Health.OverallStatus.ToString();
        }

        _ = InvokeAsync(() =>
        {
            try
            {
                UpdateConnectionStatus();
                StateHasChanged();
            }
            catch (ObjectDisposedException)
            {
                // Component disposed during async callback
            }
        });
    }

    private void OnPollingFailure(Exception ex)
    {
        _pollingFailed = true;
        _pollingSucceeded = false;
        _ = InvokeAsync(() =>
        {
            try
            {
                UpdateConnectionStatus();
                StateHasChanged();
            }
            catch (ObjectDisposedException)
            {
                // Component disposed during async callback
            }
        });
    }

    private void UpdateConnectionStatus()
    {
        bool signalRConnected = SignalRClient?.IsConnected ?? false;
        if (signalRConnected || _pollingSucceeded)
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Connected;
        }
        else if (_pollingFailed)
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Disconnected;
        }
        else
        {
            _connectionStatus = HeaderStatusIndicator.ConnectionStatusType.Unknown;
        }
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        ThemeState.Changed -= OnThemeChanged;
        RefreshService.OnDataChanged -= OnPollingSuccess;
        RefreshService.OnError -= OnPollingFailure;

        try
        {
            if (!string.IsNullOrWhiteSpace(_shortcutRegistrationId))
            {
                await JSRuntime.InvokeVoidAsync("hexalithAdmin.unregisterShortcuts", _shortcutRegistrationId);
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit already disconnected — safe to ignore
        }

        _dotNetRef?.Dispose();
    }
}
