@inject NavigationManager NavigationManager
@implements IDisposable

@if (_segments.Count > 0)
{
    <div class="admin-breadcrumb" aria-label="Breadcrumb">
        @for (int i = 0; i < _segments.Count; i++)
        {
            @if (i > 0)
            {
                <span class="separator" aria-hidden="true">/</span>
            }
            @if (i < _segments.Count - 1)
            {
                <a href="@_segments[i].Href">@_segments[i].Label</a>
            }
            else
            {
                <span class="current monospace" aria-current="page">@_segments[i].Label</span>
            }
        }
    </div>
}

@code {
    private List<BreadcrumbSegment> _segments = [];

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateSegments();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateSegments();
        StateHasChanged();
    }

    private void UpdateSegments()
    {
        _segments = [];

        Uri uri = new(NavigationManager.Uri);
        string path = uri.AbsolutePath.Trim('/');
        if (string.IsNullOrEmpty(path))
        {
            return;
        }

        _segments.Add(new BreadcrumbSegment("Home", "/"));

        string[] parts = path.Split('/');
        string currentPath = string.Empty;
        foreach (string part in parts)
        {
            currentPath += "/" + part;
            string label = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(part.Replace('-', ' '));
            _segments.Add(new BreadcrumbSegment(label, currentPath));
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private sealed record BreadcrumbSegment(string Label, string Href);
}
