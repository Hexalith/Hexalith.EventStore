{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EventStore": {
    "SignalR": {
      "Enabled": true
    },
    "ProjectionChanges": {
      "Transport": "Direct"
    },
    "DomainServices": {
      "Registrations": {
        "*|counter|v1": {
          "AppId": "sample",
          "MethodName": "process",
          "TenantId": "*",
          "Domain": "counter",
          "Version": "v1"
        },
        "*|greeting|v1": {
          "AppId": "sample",
          "MethodName": "process",
          "TenantId": "*",
          "Domain": "greeting",
          "Version": "v1"
        },
        "system|tenants|v1": {
          "AppId": "tenants",
          "MethodName": "process",
          "TenantId": "system",
          "Domain": "tenants",
          "Version": "v1"
        },
        "system|global-administrators|v1": {
          "AppId": "tenants",
          "MethodName": "process",
          "TenantId": "system",
          "Domain": "global-administrators",
          "Version": "v1"
        }
      }
    }
  },
  "Authentication": {
    "JwtBearer": {
      "Issuer": "hexalith-dev",
      "Audience": "hexalith-eventstore",
      "SigningKey": "DevOnlySigningKey-AtLeast32Chars!",
      "RequireHttpsMetadata": false
    }
  }
}
