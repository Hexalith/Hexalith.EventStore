<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsPublishable>true</IsPublishable>
    <EnableContainer>true</EnableContainer>
    <ContainerRepository>sample</ContainerRepository>
  </PropertyGroup>

  <ItemGroup>
    <!-- A domain module references only the domain-service SDK; Client, ServiceDefaults, and Contracts
         flow in transitively. All hosting boilerplate lives in the SDK. -->
    <ProjectReference Include="..\..\src\Hexalith.EventStore.DomainService\Hexalith.EventStore.DomainService.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapr.AspNetCore" />
  </ItemGroup>

</Project>
