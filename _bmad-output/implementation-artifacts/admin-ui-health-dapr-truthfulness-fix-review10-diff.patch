+    {
+        DaprHealthHistoryEntry? latestIssue = _timeline?.Entries?
+            .Where(e => e.SourceStatus is RemoteMetadataStatus.Unreachable or RemoteMetadataStatus.InvalidPayload)
+            .OrderByDescending(e => e.CapturedAtUtc)
+            .FirstOrDefault();
+        if (latestIssue is null)
+        {
+            return null;
+        }
+
+        string status = latestIssue.SourceStatus == RemoteMetadataStatus.InvalidPayload
+            ? "invalid"
+            : "unreachable";
+        return (
+            "DAPR inventory source unavailable",
+            $"The latest history sample recorded remote EventStore metadata as {status} at {latestIssue.CapturedAtUtc:HH:mm:ss}. Prior component rows may be stale until the metadata source recovers.");
+    }
+
+    private string GetSourceSummary(string component, TimeSlot slot)
+    {
+        DaprHealthHistoryEntry[] entries = _timeline?.Entries?
+            .Where(e => e.ComponentName.Equals(component, StringComparison.OrdinalIgnoreCase)
+                && e.CapturedAtUtc >= slot.Start
+                && e.CapturedAtUtc < slot.End)
+            .ToArray() ?? [];
+        if (entries.Length == 0)
+        {
+            return string.Empty;
+        }
+
+        DaprHealthHistoryEntry latest = entries.OrderByDescending(e => e.CapturedAtUtc).First();
+        if (latest.SourceStatus is RemoteMetadataStatus.Unreachable or RemoteMetadataStatus.InvalidPayload)
+        {
+            return $"source status: {latest.SourceStatus}";
+        }
+
+        if (latest.HealthEvidenceSource != DaprComponentSource.Unavailable)
+        {
+            return $"health evidence: {latest.HealthEvidenceSource}";
+        }
+
+        return latest.InventorySource == DaprComponentSource.Unavailable
+            ? string.Empty
+            : $"inventory source: {latest.InventorySource}";
+    }
