{
  "mcpServers": {
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp",
        "--nologo",
        "--non-interactive",
        "--log-level",
        "Error"
      ]
    },
    "fluent-ui-blazor": {
      "type": "stdio",
      "command": "fluentui-mcp",
      "args": []
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  }
}
